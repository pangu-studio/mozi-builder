[package]
name = "[[.Name]]"
version = "0.1.0"
description = "[[.Name]] — Tauri 桌面客户端"
edition = "2021"

[lib]
name = "[[.Name]]_lib"
crate-type = ["lib", "cdylib", "staticlib"]

[build-dependencies]
tauri-build = { version = "2", features = [] }

[dependencies]
tauri = { version = "2" }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
