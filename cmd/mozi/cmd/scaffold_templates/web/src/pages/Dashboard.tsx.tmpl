import React, { useEffect, useState } from 'react'
import { Card, Typography, Space, Tag, Spin } from 'antd'
import { CheckCircleOutlined } from '@ant-design/icons'
import { ping } from '../api'

const { Title, Paragraph } = Typography

const Dashboard: React.FC = () => {
  const [status, setStatus] = useState<string | null>(null)

  useEffect(() => {
    ping()
      .then((res) => setStatus(res.data.status))
      .catch(() => setStatus('error'))
  }, [])

  return (
    <div>
      <Title level={3}>欢迎使用 [[.Name]]</Title>
      <Paragraph type="secondary">
        基于 mozi-builder 模型驱动开发平台构建。从这里开始定义你的业务模型。
      </Paragraph>

      <Space direction="vertical" size="middle" style={{ width: '100%', marginTop: 24 }}>
        <Card>
          <Space>
            <span>API 状态：</span>
            {status === null ? (
              <Spin size="small" />
            ) : status === 'ok' ? (
              <Tag icon={<CheckCircleOutlined />} color="success">正常</Tag>
            ) : (
              <Tag color="error">异常</Tag>
            )}
          </Space>
        </Card>

        <Card title="下一步">
          <ol>
            <li>
              点击左侧 <strong>开发平台</strong> 菜单进入 mozi 模型设计器
            </li>
            <li>创建你的第一个业务模块和模型</li>
            <li>查看变更计划（change-plan）并应用到代码库</li>
          </ol>
        </Card>
      </Space>
    </div>
  )
}

export default Dashboard
