.index-page {
  padding: 32px;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 32px;

  .title {
    display: block;
    font-size: 40px;
    font-weight: 700;
    color: #4F46E5;
    margin-bottom: 8px;
  }

  .subtitle {
    display: block;
    font-size: 28px;
    color: #888;
  }
}

.card {
  background: #fff;
  border-radius: 16px;
  padding: 32px;
  margin-bottom: 24px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);

  .card-title {
    display: block;
    font-size: 30px;
    font-weight: 600;
    margin-bottom: 16px;
  }
}

.status-ok {
  color: #22c55e;
  font-size: 28px;
}

.status-error {
  color: #ef4444;
  font-size: 28px;
}

.steps {
  text {
    display: block;
    font-size: 26px;
    color: #555;
    line-height: 2;
  }
}
