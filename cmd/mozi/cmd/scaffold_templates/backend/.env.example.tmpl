# =============================================================================
# [[.Name]] — 环境变量
# =============================================================================
# 复制此文件为 .env 并填入实际值。

# 服务监听地址
[[.AddrEnv]]=:8080

# 是否启用 mozi 开发平台 API（开发环境设为 true，生产环境设为 false）
[[.DevPlatformEnv]]=true

# 设计数据库 PostgreSQL 连接串（mozi 模型定义存储）
MOZI_DB=postgres://localhost:5432/[[.ModuleBase]]_design?sslmode=disable

# 管理后台 SPA 构建产物目录
[[.AdminPathEnv]]=[[.UIDir]]/dist

# Builder 访问令牌（开发环境占位；生产环境替换为真实认证）
[[.BuilderTokenEnv]]=dev
